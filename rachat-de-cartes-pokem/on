<style>
  :root {
    --ink: #0e1116; --ink-2: #131720; --surface: #171b24; --surface-raised: #1e232e;
    --line: #262c38; --line-bright: #343c4a; --brass: #c9a15a; --brass-bright: #e8c583;
    --emerald: #3f8a68; --emerald-bright: #4fa47d; --rose: #c9607a;
    --text: #eef1f5; --muted: #8891a1; --muted-dim: #565e70; --danger: #e0838a;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background-color: var(--ink);
    background-image:
      linear-gradient(rgba(232,197,131,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,197,131,0.035) 1px, transparent 1px);
    background-size: 26px 26px;
    color: var(--text); font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased;
  }
  .wordmark { font-family: 'Space Grotesk', sans-serif; font-weight: 700; }
  .mono { font-family: 'JetBrains Mono', monospace; }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; }

  .app { display: flex; min-height: 100vh; }

  .sidebar {
    width: 216px; flex-shrink: 0; background: var(--ink-2); border-right: 1px solid var(--line);
    padding: 18px 14px; display: flex; flex-direction: column; position: sticky; top: 0; height: 100vh;
  }
  .brand { display: flex; align-items: center; gap: 9px; padding: 0 8px; margin-bottom: 22px; }
  .brand-mark { width: 30px; height: 30px; border-radius: 8px; background: linear-gradient(135deg, var(--brass), var(--emerald)); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 13px; color: var(--ink); flex-shrink: 0; }
  .brand-name { font-size: 16px; letter-spacing: -0.01em; }
  .nav-group { margin-bottom: 18px; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 8px 8px; border-radius: 8px; color: var(--muted); font-size: 13.5px; font-weight: 500; cursor: pointer; border: 1px solid transparent; }
  .nav-item svg { flex-shrink: 0; opacity: 0.8; }
  .nav-item:hover { background: var(--surface); color: var(--text); }
  .nav-item.active { background: var(--surface-raised); color: var(--brass-bright); border-color: var(--line-bright); }
  .sidebar-footer { margin-top: auto; padding: 10px 8px; border-top: 1px solid var(--line); font-size: 11px; color: var(--muted-dim); }

  .main-col { flex: 1; min-width: 0; }
  .topbar {
    position: sticky; top: 0; z-index: 20; background: rgba(14,17,22,0.9); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line); padding: 12px 26px; display: flex; gap: 10px; align-items: center;
  }
  .mobile-toggle { display: none; }
  .search-field { position: relative; flex: 1; max-width: 380px; }
  .search-field input { width: 100%; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; color: var(--text); padding: 8px 12px 8px 34px; font-size: 13px; font-family: inherit; }
  .search-field input::placeholder { color: var(--muted-dim); }
  .search-field svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--muted-dim); pointer-events: none; }
  .auth-actions { display: flex; gap: 8px; margin-left: auto; }
  .icon-btn { position: relative; width: 34px; height: 34px; border-radius: 8px; background: var(--surface); border: 1px solid var(--line); color: var(--muted); display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; }
  .icon-btn .count { position: absolute; top: -5px; right: -5px; background: var(--brass); color: var(--ink); font-size: 10px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 8px; display: flex; align-items: center; justify-content: center; padding: 0 3px; }
  .btn-ghost { background: var(--surface); border: 1px solid var(--line); color: var(--text); padding: 8px 14px; border-radius: 8px; font-size: 12.5px; font-weight: 600; cursor: pointer; white-space: nowrap; }
  .btn-primary { background: var(--brass); border: 1px solid var(--brass); color: var(--ink); padding: 8px 14px; border-radius: 8px; font-size: 12.5px; font-weight: 700; cursor: pointer; white-space: nowrap; }
  .user-chip { display: flex; align-items: center; gap: 8px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 6px 10px 6px 6px; font-size: 12.5px; }
  .user-avatar { width: 22px; height: 22px; border-radius: 50%; background: var(--emerald); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: #f4fbf7; }

  /* ---------- reveal on scroll ---------- */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ---------- hero ---------- */
  .hero { max-width: 980px; margin: 0 auto; padding: 60px 26px 30px; text-align: center; }
  .hero-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--emerald-bright); margin-bottom: 14px; }
  .hero h1 { font-family: 'Space Grotesk', sans-serif; font-size: 44px; font-weight: 700; line-height: 1.1; margin: 0 0 18px; letter-spacing: -0.02em; }
  .hero h1 span { background: linear-gradient(120deg, var(--brass-bright), var(--emerald-bright)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .hero p { font-size: 16px; color: var(--muted); max-width: 560px; margin: 0 auto 30px; line-height: 1.6; }
  .hero-cta { display: inline-flex; align-items: center; gap: 10px; background: var(--brass); color: var(--ink); font-weight: 700; font-size: 15px; padding: 15px 30px; border-radius: 11px; border: none; cursor: pointer; box-shadow: 0 12px 30px -10px rgba(201,161,90,0.5); }
  .hero-cta:hover { background: var(--brass-bright); }
  .trust-row { display: flex; justify-content: center; gap: 34px; margin-top: 42px; flex-wrap: wrap; }
  .trust-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); }
  .trust-item svg { color: var(--emerald-bright); flex-shrink: 0; }

  /* ---------- floating card decor ---------- */
  .hero-decor { position: relative; height: 90px; max-width: 500px; margin: 10px auto 0; }
  .decor-card {
    position: absolute; width: 60px; height: 82px; border-radius: 8px; background: var(--surface);
    border: 1px solid var(--line-bright); box-shadow: 0 20px 40px -15px rgba(0,0,0,0.5);
    animation: float 5s ease-in-out infinite;
  }
  .decor-card::after { content: ''; position: absolute; inset: 6px; border-radius: 5px; background: linear-gradient(135deg, rgba(201,161,90,0.25), rgba(63,138,104,0.2)); }
  .decor-card.c1 { left: calc(50% - 130px); top: 10px; animation-delay: 0s; transform: rotate(-12deg); }
  .decor-card.c2 { left: calc(50% - 32px); top: -6px; animation-delay: 0.8s; transform: rotate(-3deg); z-index: 2; }
  .decor-card.c3 { left: calc(50% + 60px); top: 14px; animation-delay: 1.6s; transform: rotate(9deg); }
  @keyframes float { 0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); } 50% { transform: translateY(-10px) rotate(var(--r, 0deg)); } }

  /* ---------- sections ---------- */
  section { max-width: 1040px; margin: 0 auto; padding: 60px 26px; }
  .section-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--brass-bright); text-align: center; margin-bottom: 10px; }
  .section-title { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 700; text-align: center; margin: 0 0 44px; letter-spacing: -0.01em; }

  /* steps */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .step { background: var(--surface); border: 1px solid var(--line); border-radius: 14px; padding: 28px 24px; position: relative; }
  .step-num { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--brass-bright); font-weight: 700; margin-bottom: 14px; }
  .step-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--surface-raised); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; color: var(--emerald-bright); }
  .step h3 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; margin: 0 0 8px; }
  .step p { font-size: 13.5px; color: var(--muted); line-height: 1.6; margin: 0; }

  /* benefits */
  .benefits { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .benefit { text-align: center; padding: 20px 14px; }
  .benefit-icon { width: 46px; height: 46px; border-radius: 12px; background: var(--surface); border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; color: var(--brass-bright); }
  .benefit h3 { font-family: 'Space Grotesk', sans-serif; font-size: 14.5px; margin: 0 0 6px; }
  .benefit p { font-size: 12.5px; color: var(--muted); line-height: 1.5; margin: 0; }

  /* what we buy */
  .buy-chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; }
  .buy-chip { padding: 8px 16px; border-radius: 999px; border: 1px solid var(--line); background: var(--surface); font-size: 13px; color: var(--muted); }

  /* faq */
  .faq-item { border: 1px solid var(--line); border-radius: 12px; margin-bottom: 10px; overflow: hidden; background: var(--surface); }
  .faq-q { padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 600; font-size: 14.5px; }
  .faq-q svg { transition: transform 0.2s; flex-shrink: 0; color: var(--muted); }
  .faq-item.open .faq-q svg { transform: rotate(180deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .faq-item.open .faq-a { max-height: 200px; }
  .faq-a-inner { padding: 0 20px 16px; font-size: 13.5px; color: var(--muted); line-height: 1.6; }

  /* form */
  .form-panel {
    max-width: 640px; margin: 0 auto; background: var(--surface); border: 1px solid var(--line-bright);
    border-radius: 18px; padding: 36px; position: relative; overflow: hidden;
  }
  .form-panel::after { content: ''; position: absolute; top: -50%; right: -10%; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(201,161,90,0.15), transparent 70%); pointer-events: none; }
  .form-panel h2 { font-family: 'Space Grotesk', sans-serif; font-size: 22px; margin: 0 0 6px; position: relative; }
  .form-panel > p { color: var(--muted); font-size: 13.5px; margin: 0 0 24px; position: relative; }
  .form-row { display: flex; gap: 12px; margin-bottom: 14px; position: relative; }
  .form-row > div { flex: 1; }
  .form-panel label { font-size: 12px; color: var(--muted); display: block; margin-bottom: 5px; font-weight: 600; }
  .form-panel input, .form-panel textarea {
    width: 100%; background: var(--surface-raised); border: 1px solid var(--line); border-radius: 9px;
    color: var(--text); padding: 10px 12px; font-size: 13.5px; font-family: inherit; resize: vertical;
  }
  .form-panel input:focus, .form-panel textarea:focus { outline: none; border-color: var(--brass); }
  .form-submit { width: 100%; padding: 14px; background: var(--emerald); color: #f4fbf7; border: none; border-radius: 10px; font-weight: 700; font-size: 15px; cursor: pointer; margin-top: 8px; position: relative; }
  .form-submit:hover { background: var(--emerald-bright); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-msg { font-size: 13px; margin-top: 12px; text-align: center; min-height: 18px; position: relative; }
  .success-state { text-align: center; padding: 20px 0; }
  .success-icon { width: 56px; height: 56px; border-radius: 50%; background: rgba(79,164,125,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; color: var(--emerald-bright); }

  footer { text-align: center; padding: 40px 26px 60px; color: var(--muted-dim); font-size: 12.5px; }

  @media (max-width: 900px) {
    .sidebar { position: fixed; left: -220px; z-index: 50; transition: left 0.2s; box-shadow: 0 0 40px rgba(0,0,0,0.5); }
    .sidebar.open { left: 0; }
    .mobile-toggle { display: flex; width: 34px; height: 34px; align-items: center; justify-content: center; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; color: var(--text); cursor: pointer; flex-shrink: 0; }
    .topbar { padding: 10px 16px; }
    .hero h1 { font-size: 30px; }
    .hero-decor { display: none; }
    .steps, .benefits { grid-template-columns: 1fr; }
    .benefits { grid-template-columns: repeat(2, 1fr); }
    section { padding: 44px 18px; }
    .form-row { flex-direction: column; gap: 0; }
    .form-panel { padding: 24px; }
  }
</style>
</head>
