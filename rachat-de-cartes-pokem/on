<script>
const SUPABASE_URL = 'https://izfusafzbekuezqitzsp.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_NYWtmqeLH0CMygyhM2R7Yw_ACYqyBCe';

function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str || '';
  return div.innerHTML;
}

let session = JSON.parse(localStorage.getItem('retrocarte_session') || 'null');
function renderAuthActions() {
  const el = document.getElementById('authActions');
  if (session && session.user) {
    const initial = (session.user.email || '?')[0].toUpperCase();
    el.innerHTML = `<div class="user-chip"><div class="user-avatar">${initial}</div>${escapeHtml(session.user.email)}</div>`;
  } else {
    el.innerHTML = `<a class="btn-ghost" href="/">Se connecter</a><a class="btn-primary" href="/">S'enregistrer</a>`;
  }
}
renderAuthActions();

document.getElementById('mobileToggle').addEventListener('click', () => document.getElementById('sidebar').classList.toggle('open'));

// stock count dans la barre latérale (cohérent avec le reste du site)
(async function loadSidebarStock() {
  try {
    const resp = await fetch(`${SUPABASE_URL}/rest/v1/cartes?select=id&status=eq.en_stock`, {
      headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` }
    });
    if (!resp.ok) return;
    const rows = await resp.json();
    document.getElementById('sidebarFooter').innerHTML = `Stock vérifié — <b>${rows.length} cartes</b><br>mis à jour en temps réel`;
  } catch (err) {}
})();

// révélation au défilement
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
}, { threshold: 0.15 });
revealEls.forEach(el => observer.observe(el));
document.getElementById('heroBlock').classList.add('visible'); // le héros apparaît tout de suite

// FAQ accordéon
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => {
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  });
});

// formulaire de demande de rachat
document.getElementById('leadSubmit').addEventListener('click', async () => {
  const nom = document.getElementById('leadNom').value.trim();
  const email = document.getElementById('leadEmail').value.trim();
  const telephone = document.getElementById('leadTel').value.trim();
  const nombre = document.getElementById('leadNombre').value.trim();
  const message = document.getElementById('leadMessage').value.trim();
  const msgEl = document.getElementById('leadMsg');
  const btn = document.getElementById('leadSubmit');

  if (!nom || !email) {
    msgEl.style.color = 'var(--danger)';
    msgEl.textContent = 'Merci de renseigner au moins ton nom et ton email.';
    return;
  }

  btn.disabled = true;
  msgEl.style.color = '';
  msgEl.textContent = 'Envoi en cours...';

  try {
    const resp = await fetch(`${SUPABASE_URL}/rest/v1/rachat_leads`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        apikey: SUPABASE_ANON_KEY,
        Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
        Prefer: 'return=minimal'
      },
      body: JSON.stringify({ nom, email, telephone, nombre_cartes: nombre, message })
    });
    if (!resp.ok) throw new Error(await resp.text());

    document.getElementById('formContent').innerHTML = `
      <div class="success-state">
        <div class="success-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg></div>
        <h2>Demande envoyée !</h2>
        <p>Merci ${escapeHtml(nom)}, on revient vers toi sous 24 à 48h avec une estimation.</p>
      </div>
    `;
  } catch (err) {
    btn.disabled = false;
    msgEl.style.color = 'var(--danger)';
    msgEl.textContent = 'Erreur lors de l\'envoi : ' + err.message;
  }
});
</script>

